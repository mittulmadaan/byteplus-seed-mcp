# fal.ai API key — required for all Seed Audio tools (current provider).
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# Provider selection. "fal" (default) today; "byteplus" once the native API ships.
# SEED_PROVIDER=fal

# Reserved for the future BytePlus native Seed Audio API.
# BYTEPLUS_SEED_API_KEY=your-byteplus-seed-key

# Optional tuning
# SEED_SUBMIT_TIMEOUT=30
# SEED_POLL_TIMEOUT=30
# SEED_MAX_RETRIES=3
# SEED_DEBUG_RAW=0
# SEED_FAL_QUEUE_BASE=https://queue.fal.run

# HTTP server mode (set to "sse" for Docker / hosted deployments)
# MCP_TRANSPORT=stdio
# PORT=8000
# MCP_AUTH_TOKEN=your-strong-random-token
