# Provider selection. "byteplus" (default) or "fal".
# SEED_PROVIDER=byteplus

# BytePlus Seed Audio (default provider). New console (recommended): single X-Api-Key.
# Get it from https://console.byteplus.com/voice/
BYTEPLUS_SEED_API_KEY=your-byteplus-seed-api-key
# Legacy console: App ID + Access Key (use INSTEAD of the API key).
# BYTEPLUS_SEED_APP_ID=your-app-id
# BYTEPLUS_SEED_ACCESS_KEY=your-access-key
# Default host is BytePlus (voice.ap-southeast-1.bytepluses.com); override to use Volcengine:
# SEED_BYTEPLUS_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/create

# fal.ai — used when SEED_PROVIDER=fal. Get one at https://fal.ai/dashboard/keys
# FAL_KEY=your-fal-api-key

# Optional tuning
# SEED_SUBMIT_TIMEOUT=30
# SEED_POLL_TIMEOUT=30
# SEED_MAX_RETRIES=3
# SEED_DEBUG_RAW=0
# SEED_FAL_QUEUE_BASE=https://queue.fal.run

# HTTP server mode (set to "sse" for Docker / hosted deployments)
# MCP_TRANSPORT=stdio
# PORT=8000
# MCP_AUTH_TOKEN=your-strong-random-token
